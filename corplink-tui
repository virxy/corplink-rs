#!/usr/bin/env bash
# corplink-tui — interactive front-end for corplink-rs
#   first run:  setup wizard (company / username / platform / extra routes / login)
#   thereafter: main menu (Switch / Reconnect / Disconnect / Status / Quit)
#
# requires: corplink-rs (this repo's binary, in same dir or $CORPLINK_HOME), fzf, jq
set -euo pipefail

# self-elevate: corplink-rs needs root for utun / DNS / route ops. On
# machines with residual EDR or corporate-VPN endpoint-security hooks
# (e.g. Sangfor EasyConnect leftovers), the user→root privilege
# transition partway through a run can get the child SIGKILL'd by
# whatever ES client is still loaded. Promoting the whole script up
# front sidesteps that transition entirely.
# Preserve HOME so we still find the per-user config under
# ~/.corplink-rs (sudo otherwise resets HOME to /var/root).
# Re-export PATH because sudo strips it to secure_path, leaving
# brew-installed fzf/jq unreachable.
if [[ $EUID -ne 0 ]]; then
    exec sudo --preserve-env=HOME "$0" "$@"
fi
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# After self-elevate, every internal `sudo XXX` adds no privilege
# (we're already root) but the real sudo binary still fork+execs
# the child through PAM / setuid. On machines with leftover EDR
# Endpoint Security hooks (Sangfor / EasyConnect / similar
# corporate-VPN stragglers), that PAM-driven exec path occasionally
# trips the hook and the child gets SIGKILL'd silently — the symptom
# was "sudo corplink-rs --list" dying with `killed` and no stderr.
# Shadow sudo with a function that just strips the leading word and
# runs the rest in-process. The earlier self-elevate (line above)
# uses /usr/bin/sudo because this function isn't defined yet; from
# this point on, every "sudo XXX" inside the script bypasses sudo
# entirely. `sudo -v` is special-cased because it has no equivalent.
sudo() {
    case "${1:-}" in
        -v) return 0 ;;
        *)  "$@" ;;
    esac
}

# resolve through any chain of symlinks (so `fl` -> ~/.corplink-rs/corplink-tui still works)
_self="$0"
while [ -L "$_self" ]; do
    _t="$(readlink "$_self")"
    if [[ "$_t" = /* ]]; then _self="$_t"; else _self="$(cd "$(dirname "$_self")" && pwd)/$_t"; fi
done
SELF_DIR="$(cd "$(dirname "$_self")" && pwd)"

ROOT="${CORPLINK_HOME:-$HOME/.corplink-rs}"
BIN="$ROOT/corplink-rs"
CONF="$ROOT/config.json"
LOG="$ROOT/run.log"
LIST_ERR="$ROOT/.list.err"

# Self-elevate writes everything as root (config, cookies, dns_backup,
# logs) — that pollutes ~/.corplink-rs so plain user tools (jq / vim /
# editors) can't read or rewrite the files afterwards. On exit, hand
# ownership back to the original invoker so the data dir stays
# user-owned. Only chown if we know the original user (sudo sets
# SUDO_USER); skip silently if invoked as root directly.
if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    _restore_ownership() {
        chown -R "$SUDO_USER" "$ROOT" 2>/dev/null || true
    }
    trap _restore_ownership EXIT INT TERM
fi
LOGIN_ERR="$ROOT/.login.err"

mkdir -p "$ROOT"

# allow running from a freshly checked-out repo (binary lives in target/release or sibling)
if [[ ! -x "$BIN" ]]; then
    for cand in "$SELF_DIR/corplink-rs" "$SELF_DIR/target/release/corplink-rs"; do
        if [[ -x "$cand" ]]; then
            cp "$cand" "$BIN"
            chmod +x "$BIN"
            break
        fi
    done
fi

err() { echo "✗ $*" >&2; }
hr()  { printf '%*s\n' "${COLUMNS:-60}" '' | tr ' ' '─'; }

# Run a command synchronously, but detach it from the controlling
# terminal first (nohup + < /dev/null + & + disown). On machines
# with leftover EDR Endpoint Security hooks (Sangfor / EasyConnect /
# similar corporate-VPN residue), the hook SIGKILL's foreground
# children of TTY-attached bash invocations of corplink-rs the
# instant they hit certain code paths (--list / --login-only seen
# dying with exit 137 / `killed`); the same binary launched via
# `nohup ... < /dev/null &` is left alone (start_with_node already
# uses this pattern for --server and works fine).
#
# Usage: _run_detached <err_file> <cmd> [args...]
#   - prints the command's stdout to *this* function's stdout,
#     so callers can do  tsv="$(_run_detached err.log $BIN --list cfg)"
#   - command's stderr is tee'd to <err_file> AND to our stderr
#   - returns the command's exit code
_run_detached() {
    local err_file="$1"; shift
    local out_file
    out_file="$(mktemp -t corplink-out)"
    : > "$err_file"
    nohup "$@" > "$out_file" 2> >(tee "$err_file" >&2) < /dev/null &
    local pid=$!
    disown "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null
    local rc=$?
    cat "$out_file"
    rm -f "$out_file"
    return $rc
}

require_cmd() {
    local missing=()
    for c in "$@"; do command -v "$c" >/dev/null 2>&1 || missing+=("$c"); done
    if (( ${#missing[@]} )); then
        err "missing: ${missing[*]}"
        echo "  install with: brew install ${missing[*]}" >&2
        exit 1
    fi
}

require_cmd fzf jq
if [[ ! -x "$BIN" ]]; then
    err "corplink-rs binary not found at $BIN"
    echo "  re-run install.sh, or build from source: cargo build --release" >&2
    exit 1
fi

iface_from_conf() { jq -r '.interface_name // empty' "$CONF" 2>/dev/null; }
current_node()    { jq -r '.vpn_server_name // empty' "$CONF" 2>/dev/null; }

is_running() {
    pgrep -f "corplink-rs.*$(basename "$CONF")" >/dev/null 2>&1
}

is_iface_up() {
    local iface; iface="$(iface_from_conf)"
    [[ -n "$iface" ]] && ifconfig "$iface" >/dev/null 2>&1
}

detect_status() {
    local iface node
    iface="$(iface_from_conf)"; iface="${iface:-?}"
    node="$(current_node)";    node="${node:-(strategy)}"
    if is_running && is_iface_up; then
        echo "● CONNECTED  node=$node  iface=$iface  log=$LOG"
    else
        echo "○ DISCONNECTED  iface=$iface  (last node: $node)"
    fi
}

# ─── setup wizard (first run) ───────────────────────────────────────────────

setup_wizard() {
    hr
    echo "首次运行,先配置一下。Ctrl+C 随时退出。"
    hr

    local company username platform iface
    local -a extra_routes=()

    read -rp "公司代号 (company_name,飞连后台分配的短码): " company
    [[ -n "$company" ]] || { err "company_name 不能为空"; exit 1; }

    read -rp "用户名 (username,通常是邮箱): " username
    [[ -n "$username" ]] || { err "username 不能为空"; exit 1; }

    platform="$(printf 'larksuite\nfeilian\nldap\nOIDC\n' \
        | fzf --prompt='platform> ' --height=30% --reverse --header='选择登录方式 (飞书/Lark 选 larksuite,LDAP 选 ldap)')"
    [[ -n "$platform" ]] || { err "未选择 platform"; exit 1; }

    echo "添加内网网段 (CIDR,直接回车结束)。例如:10.0.0.0/8"
    while true; do
        read -rp "  extra route> " r
        [[ -z "$r" ]] && break
        extra_routes+=("$r")
    done

    iface="utun$((RANDOM % 9000 + 1000))"

    local extra_json
    extra_json="$(printf '%s\n' "${extra_routes[@]:-}" | jq -R . | jq -s 'map(select(. != ""))')"

    jq -n \
        --arg company "$company" \
        --arg username "$username" \
        --arg platform "$platform" \
        --arg iface "$iface" \
        --argjson extra "$extra_json" \
        '{
            company_name: $company,
            username: $username,
            platform: $platform,
            interface_name: $iface,
            use_vpn_dns: true,
            vpn_select_strategy: "latency",
            auto_setup_routes: true,
            extra_routes: $extra
        }' > "$CONF"

    echo "✓ 写入 $CONF"
    hr
    echo "→ 触发首次登录。会拉起公司服务发现 + 飞书扫码。"
    echo "  程序会打印一个 https://applink.feishu.cn/... 的 URL,在另一个终端跑:"
    echo "      open '<那个 URL>'"
    echo "  飞书 App 弹出后授权,然后回到此终端按回车。"
    hr

    sudo -v
    _run_detached "$LOGIN_ERR" "$BIN" --login-only "$CONF" >/dev/null || {
        err "登录失败,日志:"
        tail -30 "$LOGIN_ERR" >&2
        exit 1
    }

    if [[ "$(jq -r '.state // empty' "$CONF")" != "Login" ]]; then
        err "未进入 Login 状态,看 $LOGIN_ERR"
        exit 1
    fi
    echo "✓ 登录成功"
    hr
}

# ─── actions ────────────────────────────────────────────────────────────────

stop_running() {
    sudo pkill -INT -f "corplink-rs.*$(basename "$CONF")" 2>/dev/null || true
    sudo pkill -INT -f "wg-corplink" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
        is_running || break
        sleep 1
    done
    sudo pkill -KILL -f "corplink-rs.*$(basename "$CONF")" 2>/dev/null || true
    sudo pkill -KILL -f "wg-corplink" 2>/dev/null || true
}

start_with_node() {
    local node="$1"
    # persist current node into config so detect_status / reconnect work
    local tmp; tmp="$(mktemp)"
    jq --arg n "$node" '.vpn_server_name = $n' "$CONF" > "$tmp" && mv "$tmp" "$CONF"
    sudo -v
    : > "$LOG"
    sudo nohup "$BIN" --server "$node" "$CONF" >"$LOG" 2>&1 < /dev/null &
    disown $! 2>/dev/null || true
    echo "→ 已启动,等待接口起来..."
    for _ in 1 2 3 4 5 6 7 8; do
        if is_iface_up; then
            echo "✓ $(detect_status)"
            return 0
        fi
        sleep 1
    done
    err "接口未起来,最近日志:"
    tail -30 "$LOG" >&2
    return 1
}

action_switch() {
    sudo -v
    echo "→ 拉取节点列表(每节点 ~10s,缓慢正常)。日志会实时显示在下面。"
    hr
    local tsv
    # tee stderr to both terminal (so QR-scan prompts / errors are visible)
    # and to LIST_ERR (so we can grep / report later).
    # Run detached to dodge EDR ES hook that SIGKILL's TTY-attached
    # synchronous corplink-rs invocations (see _run_detached).
    if ! tsv="$(_run_detached "$LIST_ERR" "$BIN" --list "$CONF")"; then
        hr
        err "拉取节点失败 (退出码 $?)。完整日志在 $LIST_ERR"
        echo "  常见原因 / 修法:" >&2
        echo "    cookie 过期 / 登录已过期(101)→ 选菜单的 Re-login,或" >&2
        echo "      sudo $BIN --login-only $CONF" >&2
        echo "    服务端不可达 → 检查公司网络 / 排查 $CONF 里的 server 字段" >&2
        return 1
    fi
    hr
    if [[ -z "$tsv" ]]; then
        err "服务端返回 0 节点"
        return 1
    fi

    local cur; cur="$(current_node)"
    local pick
    pick="$(printf '%s\n' "$tsv" | awk -F'\t' -v cur="$cur" '{
        marker = ($1 == cur) ? "→ " : "  "
        lat = ($3 == "-1") ? "timeout" : ($3 "ms")
        printf "%s%-20s  %-18s  %s\n", marker, $1, $2, lat
    }' | fzf --prompt='node> ' --height=50% --reverse --no-sort \
              --header='   name                  ip                  latency')"
    [[ -z "$pick" ]] && { echo "(取消)"; return 0; }
    local node; node="$(echo "$pick" | sed 's/^[→ ] *//' | awk '{print $1}')"
    echo "→ 选择 $node"
    stop_running
    start_with_node "$node"
}

action_reconnect() {
    local node; node="$(current_node)"
    if [[ -z "$node" ]]; then
        echo "(没有上次节点,改用 Switch)"
        action_switch
        return
    fi
    echo "→ 重连 $node"
    stop_running
    start_with_node "$node"
}

action_disconnect() {
    if ! is_running && ! is_iface_up; then
        echo "(已经断开)"
        return
    fi
    stop_running
    echo "✓ 已断开"
}

action_relogin() {
    hr
    echo "→ 触发重新登录。如果是飞书,程序会打印一个 https://applink.feishu.cn/... 的 URL。"
    echo "  在另一个终端跑 'open <URL>' 完成授权,然后回到此终端按回车。"
    hr
    sudo -v
    _run_detached "$LOGIN_ERR" "$BIN" --login-only "$CONF" >/dev/null || {
        err "登录失败,完整日志在 $LOGIN_ERR"
        return 1
    }
    if [[ "$(jq -r '.state // empty' "$CONF")" == "Login" ]]; then
        echo "✓ 已重新登录"
    else
        err "未进入 Login 状态,看 $LOGIN_ERR"
    fi
}

maybe_reconnect() {
    # call after a config change that needs the tunnel restarted to take effect.
    if ! is_running && ! is_iface_up; then
        echo "(未在连接,改动将在下次启动时生效)"
        return 0
    fi
    read -rp "→ 立即重连以生效?[Y/n] " ans
    case "${ans:-y}" in
        n|N|no|No) echo "(已保存,下次连接生效)" ;;
        *)
            local node; node="$(current_node)"
            stop_running
            if [[ -n "$node" ]]; then
                start_with_node "$node"
            else
                echo "(没有上次节点,改用 Switch 选一个)"
            fi
            ;;
    esac
}

list_routes() {
    jq -r '.extra_routes // [] | .[]' "$CONF" 2>/dev/null
}

action_routes() {
    local changed=0
    while true; do
        hr
        echo "当前 extra_routes (内网网段):"
        local cur; cur="$(list_routes)"
        if [[ -z "$cur" ]]; then
            echo "  (空)"
        else
            echo "$cur" | sed 's/^/  /'
        fi
        hr
        local pick
        pick="$(printf 'Add\nRemove\nDone\n' \
            | fzf --prompt='routes> ' --height=30% --reverse --no-sort \
                  --header='管理内网网段(extra_routes)')" || pick="Done"
        case "${pick:-Done}" in
            Add)
                read -rp "  新网段 (CIDR,例如 10.0.0.0/8): " r
                [[ -z "$r" ]] && continue
                local tmp; tmp="$(mktemp)"
                jq --arg r "$r" '.extra_routes = ((.extra_routes // []) + [$r] | unique)' \
                    "$CONF" > "$tmp" && mv "$tmp" "$CONF"
                echo "✓ 已添加 $r"
                changed=1
                ;;
            Remove)
                if [[ -z "$cur" ]]; then
                    echo "(空,没什么可删)"
                    continue
                fi
                local victim
                victim="$(printf '%s\n' "$cur" \
                    | fzf --prompt='remove> ' --height=30% --reverse --no-sort \
                          --header='选要删除的网段')" || victim=""
                [[ -z "$victim" ]] && continue
                local tmp; tmp="$(mktemp)"
                jq --arg r "$victim" '.extra_routes = ((.extra_routes // []) | map(select(. != $r)))' \
                    "$CONF" > "$tmp" && mv "$tmp" "$CONF"
                echo "✓ 已删除 $victim"
                changed=1
                ;;
            Done|"") break ;;
        esac
    done
    if (( changed )); then
        maybe_reconnect
    fi
}

action_full_route() {
    hr
    local cur
    cur="$(jq -r '.use_full_route // false' "$CONF")"
    local label
    [[ "$cur" == "true" ]] && label="全局 (full)" || label="分流 (split)"
    echo
    echo "  开启全局: 所有 IPv4 走 VPN。服务端下发 vpn_route_full"
    echo "            (0.0.0.0/1 + 128.0.0.0/1) — 不顶替 default route,"
    echo "            也不会让 VPN server 自身回环。"
    echo "  关闭全局: 只有公司内网/服务走 VPN,公网走原 ISP。用 vpn_route_split。"
    hr
    local pick
    pick="$(printf '开启全局模式 (full)\n关闭全局模式 (split)\n' \
        | fzf --prompt='full route> ' --height=30% --reverse --no-sort \
              --header="当前: $label  — 选目标模式")" || pick=""
    local new
    case "${pick:-}" in
        开启*) new=true ;;
        关闭*) new=false ;;
        *)     echo "(取消)"; return ;;
    esac
    if [[ "$cur" == "$new" ]]; then
        echo "(已经是 $label,无变化)"
        return
    fi
    local tmp; tmp="$(mktemp)"
    jq --argjson v "$new" '.use_full_route = $v' "$CONF" > "$tmp" \
        && mv "$tmp" "$CONF"
    echo "✓ use_full_route: $cur → $new"
    maybe_reconnect
}

action_repair_dns() {
    hr
    echo "→ 重置所有网络服务的 DNS,修复 fl 异常退出后系统 DNS 被钉死的问题"
    echo "  (背景:corplink-rs 连接时把每个服务的 DNS 改成 VPN 内部 DNS。如果"
    echo "   进程在 restore_dns 之前异常退出,改动会跨重启留在系统里,导致没有"
    echo "   VPN 时全网无法解析。)"
    hr
    echo "当前每个服务的 DNS:"
    networksetup -listallnetworkservices 2>/dev/null | tail -n +2 | while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        svc="${svc#\*}"
        local cur
        cur="$(networksetup -getdnsservers "$svc" 2>/dev/null | tr '\n' ',' | sed 's/,$//')"
        if [[ "$cur" == *"There aren"* ]]; then cur="(auto/DHCP)"; fi
        printf '  %-30s  %s\n' "$svc" "$cur"
    done
    hr
    read -rp "全部重置为 DHCP 自动?[Y/n] " ans
    case "${ans:-y}" in
        n|N|no|No) echo "(取消)"; return 0 ;;
    esac
    sudo -v
    networksetup -listallnetworkservices 2>/dev/null | tail -n +2 | while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        svc="${svc#\*}"
        if sudo networksetup -setdnsservers "$svc" Empty 2>/dev/null; then
            echo "  ✓ $svc"
        else
            echo "  ✗ $svc"
        fi
    done
    # 同步清掉 corplink-rs 留下的 backup 标记,免得下次启动反向把坏值还原回去
    if [[ -f "$ROOT/dns_backup.json" ]]; then
        sudo rm -f "$ROOT/dns_backup.json" && echo "  ✓ removed $ROOT/dns_backup.json"
    fi
    hr
    echo "现在的 DNS:"
    scutil --dns 2>/dev/null | awk '/^\s*nameserver/ {print "  " $0}' | sort -u | head -10
    hr
    echo "(回车返回菜单)"
    read -r _
}

action_status() {
    hr
    detect_status
    hr
    local iface; iface="$(iface_from_conf)"
    if [[ -n "$iface" ]] && ifconfig "$iface" >/dev/null 2>&1; then
        echo "iface $iface:"
        ifconfig "$iface" | sed 's/^/  /'
        echo
        echo "routes via $iface:"
        netstat -rn -f inet | awk -v i="$iface" '$NF == i {print "  " $0}' | head -15
    fi
    hr
    if [[ -f "$LOG" ]]; then
        echo "log tail ($LOG):"
        tail -30 "$LOG" | sed 's/^/  /'
    fi
    hr
    echo "(回车返回菜单)"
    read -r _
}

action_purge_official() {
    hr
    cat <<'EOF'
→ 清理官方飞连 (CorpLink) — 自启动 / 进程 / TCC 权限 / 网络扩展

会做:
  1. bootout 所有 com.volcengine.corplink.* / com.corplink.mdm.policy 启动项
  2. 把 plist 移到 .disabled 归档(重启不复活)
  3. kill 所有 corplink / clpolicy / sealsuite 残留进程
  4. tccutil reset 撤销 5 个相关 bundle 的 TCC 授权
  5. 检查 SealSuite 网络扩展(com.byteplus.sealsuite.networkextension),
     若仍 enabled 提示去系统设置关掉

⚠ 后果(请确认):
  - 公司 IT 会看到你的 puppet 心跳消失(一般 24h 内人工跟进)
  - 通过官方飞连建立的内网访问(Lark/git/OA 等)会断
  - 切到 fl(corplink-rs)之后再做这一步,不要让自己彻底失联
  - 此操作幂等:以后官方飞连若被自更新/IT 推送复活,重跑此项即可
EOF
    read -rp "继续?输入 'yes' 确认(其他任何输入都会取消): " ans
    [[ "$ans" == "yes" ]] || { echo "(取消)"; return; }

    sudo -v

    local user_uid timestamp
    user_uid="$(id -u)"
    timestamp="$(date +%Y%m%d-%H%M%S)"

    local -a daemon_labels=(
        com.volcengine.corplink.service
        com.volcengine.corplink.systemextension
        com.corplink.mdm.policy
    )
    local -a daemon_plists=(
        /Library/LaunchDaemons/com.volcengine.corplink.service.plist
        /Library/LaunchDaemons/com.volcengine.corplink.systemextension.plist
        /Library/LaunchDaemons/com.corplink.mdm.policy.plist
    )
    local -a sysagent_labels=(com.volcengine.corplink.agent)
    local -a sysagent_plists=(/Library/LaunchAgents/com.volcengine.corplink.agent.plist)
    local -a useragent_labels=(CorpLink)
    local -a useragent_plists=("$HOME/Library/LaunchAgents/CorpLink.plist")
    local -a kill_patterns=(
        CorpLinkExtension
        corplink-service
        clpolicy
        CorplinkNe
        "/Applications/CorpLink.app/Contents/MacOS/CorpLink"
        "CorpLink Helper"
    )
    local -a tcc_bundles=(
        com.volcengine.corplink
        com.volcengine.corplink.networkextension-wrapper
        com.volcengine.corplink.systemextension
        com.byteplus.sealsuite.networkextension
        com.byteplus.sealsuite.networkextension-controller
    )

    hr
    echo "1. bootout 启动项"
    for l in "${daemon_labels[@]}"; do
        if sudo launchctl print "system/$l" >/dev/null 2>&1; then
            sudo launchctl bootout "system/$l" 2>/dev/null && echo "  ✓ system/$l"
        fi
    done
    for l in "${sysagent_labels[@]}"; do
        if sudo launchctl print "gui/$user_uid/$l" >/dev/null 2>&1; then
            sudo launchctl bootout "gui/$user_uid/$l" 2>/dev/null && echo "  ✓ gui/$user_uid/$l"
        fi
    done
    for l in "${useragent_labels[@]}"; do
        if launchctl print "gui/$user_uid/$l" >/dev/null 2>&1; then
            launchctl bootout "gui/$user_uid/$l" 2>/dev/null && echo "  ✓ gui/$user_uid/$l"
        fi
    done

    echo
    echo "2. 移走 plist"
    sudo mkdir -p /Library/LaunchDaemons.disabled /Library/LaunchAgents.disabled
    for p in "${daemon_plists[@]}"; do
        if [[ -f "$p" ]]; then
            sudo mv "$p" "/Library/LaunchDaemons.disabled/$(basename "$p").$timestamp" \
                && echo "  ✓ $(basename "$p")"
        fi
    done
    for p in "${sysagent_plists[@]}"; do
        if [[ -f "$p" ]]; then
            sudo mv "$p" "/Library/LaunchAgents.disabled/$(basename "$p").$timestamp" \
                && echo "  ✓ $(basename "$p")"
        fi
    done
    for p in "${useragent_plists[@]}"; do
        if [[ -f "$p" ]]; then
            mv "$p" "$p.disabled.$timestamp" && echo "  ✓ $(basename "$p") (self-heal 复活检测)"
        fi
    done

    echo
    echo "3. kill 残留进程"
    local killed=0 pids pid
    for pat in "${kill_patterns[@]}"; do
        pids="$(pgrep -f "$pat" 2>/dev/null || true)"
        for pid in $pids; do
            if sudo kill -9 "$pid" 2>/dev/null; then
                echo "  ✓ pid=$pid ($pat)"
                killed=$((killed+1))
            fi
        done
    done
    (( killed == 0 )) && echo "  (无残留)"

    echo
    echo "4. 撤销 TCC 权限"
    local out
    for bid in "${tcc_bundles[@]}"; do
        out="$(tccutil reset All "$bid" 2>&1 || true)"
        case "$out" in
            Successfully*)         echo "  ✓ $bid" ;;
            *"No such bundle"*)    : ;;  # bundle 不存在,跳过
            *)                     echo "  ! $bid: $out" ;;
        esac
    done

    echo
    echo "5. 系统扩展状态"
    local se
    se="$(systemextensionsctl list 2>/dev/null | grep -iE "sealsuite|corplink|volcengine|byteplus" || true)"
    if [[ -n "$se" ]]; then
        echo "$se" | sed 's/^/  /'
        if echo "$se" | grep -q "activated enabled"; then
            echo
            echo "  ⚠ 还在拦流量。命令行 systemextensionsctl uninstall 受 SIP 限制大概率失败,"
            echo "     最稳的办法是 GUI 关:"
            echo "     系统设置 → 通用 → 登录项与扩展 → 网络扩展 → 关掉 SealSuite 开关"
            read -rp "  → 现在打开系统设置?[Y/n] " ans
            case "${ans:-y}" in
                n|N|no|No) ;;
                *) open "x-apple.systempreferences:com.apple.LoginItems-Settings.extension" 2>/dev/null \
                   || open "/System/Library/PreferencePanes/Extensions.prefPane" 2>/dev/null ;;
            esac
        fi
    else
        echo "  ✓ 列表中已无飞连相关扩展"
    fi

    hr
    echo "✓ 清理完成。残留进程:"
    if pgrep -f -E "corplink|clpolicy|sealsuite|byteplus|volcengine" >/dev/null 2>&1; then
        ps -eo pid,user,comm | grep -iE "corplink|clpolicy|sealsuite|byteplus|volcengine" | grep -v grep | sed 's/^/  /'
    else
        echo "  (无)"
    fi
    hr
    echo "(回车返回菜单)"
    read -r _
}

# ─── main ───────────────────────────────────────────────────────────────────

[[ -f "$CONF" ]] || setup_wizard

while true; do
    status="$(detect_status)"
    pick="$(printf 'Switch node\nReconnect\nDisconnect\nRoutes\nFull route\nStatus\nRe-login\nRepair DNS\nPurge official Feilian\nQuit\n' \
        | fzf --prompt='action> ' --height=40% --reverse --no-sort \
              --header="$status")" || pick=""
    case "${pick:-}" in
        "Switch node")              action_switch ;;
        "Reconnect")                action_reconnect ;;
        "Disconnect")               action_disconnect ;;
        "Routes")                   action_routes ;;
        "Full route")               action_full_route ;;
        "Status")                   action_status ;;
        "Re-login")                 action_relogin ;;
        "Repair DNS")               action_repair_dns ;;
        "Purge official Feilian")   action_purge_official ;;
        "Quit"|"")                  exit 0 ;;
    esac
done
